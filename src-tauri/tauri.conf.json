{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills Manager",
  "version": "0.1.0",
  "identifier": "com.skill-sync.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skills Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
