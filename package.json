{
  "name": "skill-sync-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420 --strictPort",
    "native:dev": "cargo run --manifest-path src-tauri/Cargo.toml",
